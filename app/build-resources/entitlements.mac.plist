<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow the app to be run on macOS -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    
    <!-- Allow hardened runtime -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    
    <!-- Camera access for facial expression analysis -->
    <key>com.apple.security.device.camera</key>
    <true/>
    
    <!-- Microphone access for voice emotion analysis -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    
    <!-- Bluetooth access for heart rate monitor and massage chair -->
    <key>com.apple.security.device.bluetooth</key>
    <true/>
    
    <!-- Network access for local API communication -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
    
    <!-- File access for local data storage -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
